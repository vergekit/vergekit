---
interface Props {
  appName: string;
  name?: string | null;
  resetUrl: string;
}

const { appName, name, resetUrl } = Astro.props;
const greeting = name ? `Hi ${name},` : 'Hi,';
---

<html lang="en">
  <head>
    <title>Reset your {appName} password</title>
  </head>
  <body style="margin:0;background-color:#f8fafc;font-family:Arial,sans-serif;">
    <div
      style="display:none;overflow:hidden;line-height:1px;opacity:0;max-height:0;max-width:0;"
    >
      Reset your {appName} password.
    </div>
    <table
      width="100%"
      border="0"
      cellpadding="0"
      cellspacing="0"
      role="presentation"
    >
      <tbody>
        <tr>
          <td align="center" style="padding:32px 16px;">
            <table
              width="100%"
              border="0"
              cellpadding="0"
              cellspacing="0"
              role="presentation"
              style="max-width:560px;background-color:#ffffff;border:1px solid #e2e8f0;"
            >
              <tbody>
                <tr>
                  <td style="padding:32px;">
                    <h1
                      style="margin:0 0 16px;color:#0f172a;font-size:24px;line-height:32px;"
                    >
                      Reset password
                    </h1>
                    <p
                      style="margin:0 0 20px;color:#334155;font-size:16px;line-height:24px;"
                    >
                      {greeting} use the button below to choose a new password for
                      {appName}.
                    </p>
                    <a
                      href={resetUrl}
                      style="display:inline-block;background-color:#0f172a;color:#ffffff;padding:12px 18px;font-weight:700;text-decoration:none;"
                    >
                      Reset password
                    </a>
                    <hr
                      style="border:none;border-top:1px solid #e2e8f0;margin:28px 0;"
                    />
                    <p
                      style="margin:0 0 12px;color:#64748b;font-size:13px;line-height:20px;"
                    >
                      If you did not request a password reset, you can ignore
                      this email.
                    </p>
                    <p
                      style="margin:0;color:#64748b;font-size:13px;line-height:20px;"
                    >
                      {resetUrl}
                    </p>
                  </td>
                </tr>
              </tbody>
            </table>
          </td>
        </tr>
      </tbody>
    </table>
  </body>
</html>
