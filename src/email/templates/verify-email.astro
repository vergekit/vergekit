---
import {
  Body,
  Button,
  Container,
  Head,
  Heading,
  Hr,
  Html,
  Preview,
  Section,
  Text,
} from '@backstro/email';

interface Props {
  appName: string;
  name?: string | null;
  verificationUrl: string;
}

const { appName, name, verificationUrl } = Astro.props;
const greeting = name ? `Hi ${name},` : 'Hi,';

const bodyStyle = {
  margin: '0',
  backgroundColor: '#f8fafc',
  fontFamily: 'Arial, sans-serif',
};

const outerSectionStyle = {
  padding: '32px 16px',
};

const cardStyle = {
  maxWidth: '560px',
  backgroundColor: '#ffffff',
  border: '1px solid #e2e8f0',
};

const contentStyle = {
  padding: '32px',
};

const headingStyle = {
  color: '#0f172a',
  fontSize: '24px',
  lineHeight: '32px',
};

const bodyTextStyle = {
  margin: '0',
  marginTop: '0',
  marginBottom: '20px',
  color: '#334155',
  fontSize: '16px',
  lineHeight: '24px',
};

const buttonStyle = {
  backgroundColor: '#0f172a',
  color: '#ffffff',
  padding: '12px 18px',
  fontWeight: 700,
};

const dividerStyle = {
  borderTop: '1px solid #e2e8f0',
  margin: '28px 0',
};

const footerTextStyle = {
  margin: '0',
  marginTop: '0',
  marginBottom: '12px',
  color: '#64748b',
  fontSize: '13px',
  lineHeight: '20px',
};

const urlTextStyle = {
  ...footerTextStyle,
  marginBottom: '0',
};
---

<Html lang="en">
  <Head>
    <title>Verify your {appName} email</title>
  </Head>
  <Body style={bodyStyle}>
    <Preview>Confirm your email address for {appName}.</Preview>
    <Section style={outerSectionStyle}>
      <Container style={cardStyle}>
        <Section style={contentStyle}>
          <Heading as="h1" mt={0} mb={16} style={headingStyle}>
            Confirm email address
          </Heading>
          <Text style={bodyTextStyle}>
            {greeting} use the button below to verify your email address for {
              appName
            }.
          </Text>
          <Button href={verificationUrl} style={buttonStyle}>
            Confirm email address
          </Button>
          <Hr style={dividerStyle} />
          <Text style={footerTextStyle}>
            If you did not create an account, you can ignore this email.
          </Text>
          <Text style={urlTextStyle}>
            {verificationUrl}
          </Text>
        </Section>
      </Container>
    </Section>
  </Body>
</Html>
