---
import AuthShell from '@/components/auth/AuthShell.astro';
import { UserPlusIcon } from '@lucide/astro';
import { Field, FieldLabel } from '@/components/ui/field';
import { appConfig } from '@/config/app';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
---

<AuthShell
  title="Create your account"
  eyebrow="Start secure"
  description="Create a secure workspace account."
>
  <div class="mb-8 hidden lg:block">
    <h2 class="text-2xl font-semibold tracking-normal text-slate-950">
      Register
    </h2>
    <p class="mt-2 text-sm leading-6 text-slate-600">
      Set up your profile with email and password credentials.
    </p>
  </div>

  <form
    method="post"
    action="/api/auth/sign-up/email"
    class="space-y-5"
    data-auth-form
    data-auth-error="register-error"
    data-auth-success-url="/auth/check-email"
  >
    <input
      type="hidden"
      name="callbackURL"
      value={appConfig.defaultAuthenticatedPath}
    />

    <p
      id="register-error"
      class="rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-700"
      role="alert"
      aria-live="polite"
      hidden
    >
    </p>

    <Field>
      <FieldLabel for="register-name">Name</FieldLabel>
      <Input
        id="register-name"
        name="name"
        autocomplete="name"
        required
      />
    </Field>

    <Field>
      <FieldLabel for="register-email">Email</FieldLabel>
      <Input
        id="register-email"
        name="email"
        type="email"
        autocomplete="email"
        required
      />
    </Field>

    <Field>
      <FieldLabel for="register-password">Password</FieldLabel>
      <Input
        id="register-password"
        name="password"
        type="password"
        autocomplete="new-password"
        minlength="8"
        required
      />
    </Field>

    <Button type="submit" class="w-full">
      <UserPlusIcon aria-hidden="true" />
      Create account
    </Button>
  </form>

  <p class="mt-6 text-center text-sm text-slate-600">
    Already registered? &nbsp;
    <a href="/login" class="text-slate-600 underline hover:opacity-75">
      Sign in
    </a>
  </p>

</AuthShell>
