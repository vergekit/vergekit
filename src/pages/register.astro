---
import AuthShell from '@/components/auth/AuthShell.astro';
import Field from '@/components/ui/form/Field.astro';
import Icon from '@/components/ui/Icon.astro';
import { appConfig } from '@/config/app';
import Button from '@/components/ui/form/Button.astro';
import Input from '@/components/ui/form/Input.astro';
---

<AuthShell
  title="Create your account"
  eyebrow="Start secure"
  description="Create a secure workspace account."
>
  <div class="mb-8 hidden lg:block">
    <h2 class="text-2xl font-semibold tracking-normal text-slate-950">
      Register
    </h2>
    <p class="mt-2 text-sm leading-6 text-slate-600">
      Set up your profile with email and password credentials.
    </p>
  </div>

  <form
    method="post"
    action="/api/auth/sign-up/email"
    class="space-y-5"
    data-auth-form
    data-auth-error="register-error"
  >
    <input
      type="hidden"
      name="callbackURL"
      value={appConfig.defaultAuthenticatedPath}
    />

    <p
      id="register-error"
      class="rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-700"
      role="alert"
      aria-live="polite"
      hidden
    >
    </p>

    <Field id="register-name" label="Name" required>
      <Input
        id="register-name"
        name="name"
        autocomplete="name"
        placeholder="Ada Lovelace"
        required
      />
    </Field>

    <Field id="register-email" label="Email" required>
      <Input
        id="register-email"
        name="email"
        type="email"
        autocomplete="email"
        placeholder="you@example.com"
        required
      />
    </Field>

    <Field id="register-password" label="Password" required>
      <Input
        id="register-password"
        name="password"
        type="password"
        autocomplete="new-password"
        minlength="8"
        required
      />
    </Field>

    <Button type="submit" class="w-full">
      <Icon name="user-plus" size={18} aria-hidden="true" />
      Create account
    </Button>
  </form>

  <p class="mt-6 text-center text-sm text-slate-600">
    Already registered?
    <a href="/login" class="font-medium text-slate-950 hover:text-emerald-700">
      Sign in
    </a>
  </p>

  <script>
    import { mountAuthForms } from '@vergekit/core/auth';
    import { appConfig } from '@/config/app';
    import { authConfig } from '@/config/auth';

    mountAuthForms(document, {
      authConfig,
      defaultSuccessRedirect: appConfig.defaultAuthenticatedPath,
    });
  </script>
</AuthShell>
