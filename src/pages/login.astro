---
import AuthShell from '@/components/auth/AuthShell.astro';
import Field from '@/components/ui/form/Field.astro';
import { appConfig } from '@/config/app';
import Button from '@/components/ui/form/Button.astro';
import Input from '@/components/ui/form/Input.astro';

const redirectTo =
  Astro.url.searchParams.get('redirectTo') ??
  appConfig.defaultAuthenticatedPath;
---

<AuthShell
  title={`Sign in to ${appConfig.name}`}
  eyebrow="Welcome back"
  description="Secure access for your workspace."
>
  <div class="mb-8 hidden lg:block">
    <h2 class="text-2xl font-semibold tracking-normal text-slate-950">
      Sign in
    </h2>
    <p class="mt-2 text-sm leading-6 text-slate-600">
      Continue with your account credentials.
    </p>
  </div>

  <form
    method="post"
    action="/api/auth/sign-in/email"
    class="space-y-5"
    data-auth-form
    data-auth-error="login-error"
  >
    <input type="hidden" name="callbackURL" value={redirectTo} />

    <p
      id="login-error"
      class="rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-700"
      role="alert"
      aria-live="polite"
      hidden
    >
    </p>

    <Field id="login-email" label="Email" required>
      <Input
        id="login-email"
        name="email"
        type="email"
        autocomplete="email"
        placeholder="you@example.com"
        required
      />
    </Field>

    <Field id="login-password" label="Password" required>
      <Input
        id="login-password"
        name="password"
        type="password"
        autocomplete="current-password"
        required
      />
    </Field>

    <div class="flex items-center justify-between gap-4 text-sm">
      <label class="inline-flex items-center gap-2 text-slate-600">
        <input
          type="checkbox"
          name="rememberMe"
          value="true"
          checked
          class="size-4 rounded border-slate-300 text-slate-950 focus:ring-slate-400"
        />
        Remember me
      </label>

      <a
        href="/auth/forgot-password"
        class="font-medium text-slate-950 hover:text-emerald-700"
      >
        Forgot password?
      </a>
    </div>

    <Button type="submit" class="w-full">
      Sign in
    </Button>
  </form>

  <p class="mt-6 text-center text-sm text-slate-600">
    New here?
    <a
      href="/register"
      class="font-medium text-slate-950 hover:text-emerald-700"
    >
      Create an account
    </a>
  </p>

  <script>
    import { mountAuthForms } from '@vergekit/core/auth';
    import { appConfig } from '@/config/app';
    import { authConfig } from '@/config/auth';

    mountAuthForms(document, {
      authConfig,
      defaultSuccessRedirect: appConfig.defaultAuthenticatedPath,
    });
  </script>
</AuthShell>
