---
import AuthShell from "@/components/auth/AuthShell.astro";
import { MailIcon } from "@lucide/astro";
import { Field, FieldLabel } from "@/components/ui/field";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";

const requestSent = Astro.url.searchParams.get("sent") === "1";
---

<AuthShell
  title="Reset your password"
  eyebrow="Account recovery"
  description="Get back into your account"
>
  <div class="mb-8 hidden lg:block">
    <h2 class="text-2xl font-semibold tracking-normal text-slate-950">
      Password reset
    </h2>
    <p class="mt-2 text-sm leading-6 text-slate-600">
      Enter the email address associated with your account.
    </p>
  </div>

  {
    requestSent ? (
      <div class="text-center">
        <div class="mx-auto flex size-12 items-center justify-center rounded-full bg-emerald-50 text-emerald-700">
          <MailIcon aria-hidden="true" />
        </div>

        <h2 class="mt-6 text-2xl font-semibold tracking-normal text-slate-950">
          Check your inbox
        </h2>
        <p class="mt-3 text-sm leading-6 text-slate-600">
          If an account exists for that address, we sent it a password reset
          link.
        </p>

        <Button as="a" href="/login" variant="outline" class="mt-8 w-full">
          Back to sign in
        </Button>
      </div>
    ) : (
      <form
        method="post"
        action="/api/auth/request-password-reset"
        class="space-y-5"
        data-auth-form
        data-auth-error="forgot-password-error"
        data-auth-success-url="/auth/forgot-password?sent=1"
      >
        <input type="hidden" name="redirectTo" value="/auth/reset-password" />

        <p
          id="forgot-password-error"
          class="rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-700"
          role="alert"
          aria-live="polite"
          hidden
        />

        <Field>
          <FieldLabel for="reset-email">Email</FieldLabel>
          <Input
            id="reset-email"
            name="email"
            type="email"
            autocomplete="email"
            required
          />
        </Field>

        <Button type="submit" class="w-full">
          <MailIcon aria-hidden="true" />
          Send reset link
        </Button>
      </form>
    )
  }

  <p class="mt-6 text-center text-sm text-slate-600">
    Remembered it? &nbsp;
    <a href="/login" class="text-slate-600 underline hover:opacity-75">
      Back to sign in
    </a>
  </p>
</AuthShell>
