---
import AuthShell from '@/components/auth/AuthShell.astro';
import Button from '@/components/ui/Button.astro';
import Field from '@/components/ui/Field.astro';
import Icon from '@/components/ui/Icon.astro';
import Input from '@/components/ui/Input.astro';
import { appConfig } from '@/config/app';
---

<AuthShell
  title="Reset your password"
  eyebrow="Account recovery"
  description="Get back into your account."
>
  <div class="mb-8 hidden lg:block">
    <h2 class="text-2xl font-semibold tracking-normal text-slate-950">
      Password reset
    </h2>
    <p class="mt-2 text-sm leading-6 text-slate-600">
      Use the email address connected to your {appConfig.name} account.
    </p>
  </div>

  <form
    method="post"
    action="/api/auth/request-password-reset"
    class="space-y-5"
  >
    <input type="hidden" name="redirectTo" value="/auth/reset-password" />

    <Field id="reset-email" label="Email" required>
      <Input
        id="reset-email"
        name="email"
        type="email"
        autocomplete="email"
        placeholder="you@example.com"
        required
      />
    </Field>

    <Button type="submit" fullWidth>
      <Icon name="mail" size={18} aria-hidden="true" />
      Send reset link
    </Button>
  </form>

  <p class="mt-6 text-center text-sm text-slate-600">
    Remembered it?
    <a href="/login" class="font-medium text-slate-950 hover:text-emerald-700">
      Back to sign in
    </a>
  </p>
</AuthShell>
