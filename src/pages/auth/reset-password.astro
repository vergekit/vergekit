---
import AuthShell from '@/components/auth/AuthShell.astro';
import { KeyRoundIcon } from '@lucide/astro';
import { Field, FieldLabel } from '@/components/ui/field';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';

const token = Astro.url.searchParams.get('token') ?? '';
---

<AuthShell
  title="Choose a new password"
  eyebrow="Account recovery"
  description="Set a new password for your account."
>
  <div class="mb-8 hidden lg:block">
    <h2 class="text-2xl font-semibold tracking-normal text-slate-950">
      New password
    </h2>
    <p class="mt-2 text-sm leading-6 text-slate-600">
      Set the replacement password for your account.
    </p>
  </div>

  <form method="post" action="/api/auth/reset-password" class="space-y-5">
    <input type="hidden" name="token" value={token} />

    <Field>
      <FieldLabel for="new-password">New password</FieldLabel>
      <Input
        id="new-password"
        name="newPassword"
        type="password"
        autocomplete="new-password"
        minlength="8"
        required
      />
    </Field>

    <Button type="submit" class="w-full">
      <KeyRoundIcon aria-hidden="true" />
      Update password
    </Button>
  </form>

  <p class="mt-6 text-center text-sm text-slate-600">
    Need a fresh link?
    <a
      href="/auth/forgot-password"
      class="font-medium text-slate-950 hover:text-emerald-700"
    >
      Request one
    </a>
  </p>
</AuthShell>
