---
import AuthShell from '@/components/auth/AuthShell.astro';
import { BadgeCheckIcon } from '@lucide/astro';
import { Field, FieldLabel } from '@/components/ui/field';
import { appConfig } from '@/config/app';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
---

<AuthShell
  title="Verify your email"
  eyebrow="Confirm ownership"
  description="Confirm the address tied to your account"
>
  <div class="mb-8 hidden lg:block">
    <h2 class="text-2xl font-semibold tracking-normal text-slate-950">
      Email verification
    </h2>
    <p class="mt-2 text-sm leading-6 text-slate-600">
      Send a new verification message.
    </p>
  </div>

  <form
    method="post"
    action="/api/auth/send-verification-email"
    class="space-y-5"
    data-auth-form
    data-auth-error="verify-email-error"
    data-auth-success-url="/auth/check-email"
  >
    <input
      type="hidden"
      name="callbackURL"
      value={appConfig.defaultAuthenticatedPath}
    />

    <p
      id="verify-email-error"
      class="rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-700"
      role="alert"
      aria-live="polite"
      hidden
    />

    <Field>
      <FieldLabel for="verify-email">Email</FieldLabel>
      <Input
        id="verify-email"
        name="email"
        type="email"
        autocomplete="email"
        required
      />
    </Field>

    <Button type="submit" class="w-full">
      <BadgeCheckIcon aria-hidden="true" />
      Send verification
    </Button>
  </form>

  <p class="mt-6 text-center text-sm text-slate-600">
    Already verified? &nbsp;
    <a href="/login" class="text-slate-600 underline hover:opacity-75">
      Sign in
    </a>
  </p>
</AuthShell>
