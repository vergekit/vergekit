---
import { asc } from "drizzle-orm";
import { CircleUserRoundIcon, DatabaseIcon, SettingsIcon, TicketsPlaneIcon } from "@lucide/astro";
import AuthenticatedLayout from "@/layouts/AuthenticatedLayout.astro";
import { appConfig } from "@/config/app";
import { user as userTable } from "@/config/schema";
import { db } from "@/db";

const user = Astro.locals.user;
const session = Astro.locals.session;
const displayName = user?.name || user?.email || "Authenticated user";
const formatDateTime = (date: Date | undefined) =>
  date
    ? new Intl.DateTimeFormat("en", {
        dateStyle: "medium",
        timeStyle: "short",
      }).format(date)
    : "—";

const formatDate = (date: Date | undefined) =>
  new Intl.DateTimeFormat("en", { dateStyle: "medium" }).format(date);

const allUsers = await db
  .select({
    name: userTable.name,
    email: userTable.email,
    role: userTable.role,
    createdAt: userTable.createdAt,
  })
  .from(userTable)
  .orderBy(asc(userTable.createdAt));
---

<AuthenticatedLayout title={`Dashboard | ${appConfig.name}`}>
  <div class="mx-auto w-full max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
    <section
      class="grid gap-6 rounded-xl border border-slate-200 bg-white p-6 shadow-sm md:grid-cols-[1.15fr_0.85fr]"
    >
      <div class="max-w-xl">
        <h1 class="text-3xl font-semibold tracking-normal text-slate-700">
          Welcome, {displayName}!
        </h1>
        <p class="mt-3 text-sm leading-6 text-slate-600">
          Use this template as a base to build the dashboard for logged-in
          users.
        </p>
        <p class="mt-3 text-sm leading-6 text-slate-600">
          We've already taken care of hard parts required for starting an app,
          so from this point you can have your agent responsibly produce any
          functionality you can imagine.
        </p>
        <p class="mt-3 text-sm leading-6 text-slate-600">
          The sky is truly the limit.
        </p>
        <div class="flex items-center justify-center mt-4">
          <TicketsPlaneIcon class="size-16 text-gray-300" aria-hidden="true" />
        </div>
      </div>

      <div class="grid gap-6 text-sm">
        <div class="rounded-lg border border-slate-200 bg-slate-50/40 p-4">
          <div class="flex items-center gap-3 font-medium text-slate-700">
            <SettingsIcon aria-hidden="true" />
            Account
          </div>
          <p class="mt-2 text-slate-600">
            Name: {user?.name ?? "—"} ({user?.role ?? "user"})
          </p>
          <p class="mt-1 text-slate-600">Email: {user?.email ?? "—"}</p>
          <p class="mt-1 text-slate-600">
            Joined: {formatDateTime(user?.createdAt)}
          </p>
        </div>

        <div class="rounded-lg border border-slate-200 bg-slate-50/40 p-4">
          <div class="flex items-center gap-3 font-medium text-slate-700">
            <DatabaseIcon aria-hidden="true" />
            Session
          </div>
          <p class="mt-2 text-slate-600">
            Created: {formatDateTime(session?.createdAt)}
          </p>
          <p class="mt-1 text-slate-600">
            Expires: {formatDateTime(session?.expiresAt)}
          </p>
        </div>
      </div>

      <div
        class="rounded-lg border border-slate-200 bg-slate-50/40 p-4 md:col-span-2"
      >
        <div class="gap-3">
          <div class="flex items-center gap-3 font-medium text-slate-700">
            <CircleUserRoundIcon aria-hidden="true" />
            All users
          </div>
          <p class="text-slate-500 text-xs mt-3">
            {allUsers.length} user{allUsers.length === 1 ? "" : "s"} in the system
          </p>
        </div>

        {
          allUsers.length > 0 ? (
            <div class="mt-4 overflow-x-auto">
              <table class="w-full text-left text-sm">
                <thead>
                  <tr class="border-b border-slate-200 text-slate-500">
                    <th class="pb-2 pr-4 font-medium">Name</th>
                    <th class="pb-2 pr-4 font-medium">Email</th>
                    <th class="pb-2 pr-4 font-medium">Role</th>
                    <th class="pb-2 font-medium">Joined</th>
                  </tr>
                </thead>
                <tbody>
                  {allUsers.map((row) => (
                    <tr class="border-b border-slate-100 last:border-0">
                      <td class="py-2 pr-4 text-slate-700">{row.name}</td>
                      <td class="py-2 pr-4 text-slate-600">{row.email}</td>
                      <td class="py-2 pr-4 text-slate-600">
                        {row.role ?? "user"}
                      </td>
                      <td class="py-2 text-slate-600">
                        {formatDate(row.createdAt)}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          ) : (
            <p class="mt-4 text-slate-500">No users found.</p>
          )
        }
      </div>
    </section>
  </div>
</AuthenticatedLayout>
