---
import { asc } from "drizzle-orm";
import { CircleUserRoundIcon, DatabaseIcon, LogOutIcon } from "@lucide/astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { appConfig } from "@/config/app";
import { user as userTable } from "@/config/schema";
import { Button } from "@/components/ui/button";
import { db } from "@/db";

const user = Astro.locals.user;
const session = Astro.locals.session;
const displayName = user?.name || user?.email || "Authenticated user";
const sessionExpiresAt = session?.expiresAt
  ? new Intl.DateTimeFormat("en", {
      dateStyle: "medium",
      timeStyle: "short",
    }).format(session.expiresAt)
  : "Active session";

const allUsers = await db
  .select({
    name: userTable.name,
    email: userTable.email,
    role: userTable.role,
    createdAt: userTable.createdAt,
  })
  .from(userTable)
  .orderBy(asc(userTable.createdAt));

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("en", { dateStyle: "medium" }).format(date);
---

<BaseLayout title={`Dashboard | ${appConfig.name}`}>
  <main class="min-h-screen bg-slate-50 text-slate-950">
    <header class="border-b border-slate-200 bg-white">
      <div
        class="mx-auto flex w-full max-w-6xl items-center justify-between gap-4 px-4 py-4 sm:px-6 lg:px-8"
      >
        <a href="/" class="inline-flex items-center gap-3 font-semibold">
          <img src="/favicon.svg" alt={appConfig.name} class="h-6" />
          <span>{appConfig.name}</span>
        </a>

        <form method="post" action="/api/auth/sign-out">
          <input type="hidden" name="redirectTo" value={appConfig.homePath} />
          <Button
            type="submit"
            variant="outline"
            size="sm"
            class="cursor-pointer"
          >
            <LogOutIcon aria-hidden="true" />
            Sign out
          </Button>
        </form>
      </div>
    </header>

    <div class="mx-auto w-full max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
      <section
        class="grid gap-6 rounded-xl border border-slate-200 bg-white p-6 shadow-sm md:grid-cols-[1.15fr_0.85fr]"
      >
        <div>
          <p class="text-sm font-medium text-emerald-700">✅ Authenticated</p>
          <h1
            class="mt-3 text-3xl font-semibold tracking-normal text-slate-950"
          >
            Welcome, {displayName}!
          </h1>
          <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-600">
            Your account is active.
          </p>
        </div>

        <div class="grid gap-3 text-sm">
          <div class="rounded-lg border border-slate-200 bg-slate-50 p-4">
            <div class="flex items-center gap-3 font-medium text-slate-950">
              <CircleUserRoundIcon aria-hidden="true" />
              Account
            </div>
            <p class="mt-2 text-slate-600">{user?.email ?? "No email found"}</p>
          </div>

          <div class="rounded-lg border border-slate-200 bg-slate-50 p-4">
            <div class="flex items-center gap-3 font-medium text-slate-950">
              <DatabaseIcon aria-hidden="true" />
              Session
            </div>
            <p class="mt-2 text-slate-600">{sessionExpiresAt}</p>
          </div>
        </div>

        <div
          class="rounded-lg border border-slate-200 bg-slate-50 p-4 md:col-span-2"
        >
          <div class="flex items-center gap-3 font-medium text-slate-950">
            <CircleUserRoundIcon aria-hidden="true" />
            All users
          </div>
          <p class="mt-2 text-slate-600">
            {allUsers.length} user{allUsers.length === 1 ? "" : "s"} in the system
          </p>

          {
            allUsers.length > 0 ? (
              <div class="mt-4 overflow-x-auto">
                <table class="w-full text-left text-sm">
                  <thead>
                    <tr class="border-b border-slate-200 text-slate-500">
                      <th class="pb-2 pr-4 font-medium">Name</th>
                      <th class="pb-2 pr-4 font-medium">Email</th>
                      <th class="pb-2 pr-4 font-medium">Role</th>
                      <th class="pb-2 font-medium">Joined</th>
                    </tr>
                  </thead>
                  <tbody>
                    {allUsers.map((row) => (
                      <tr class="border-b border-slate-100 last:border-0">
                        <td class="py-2 pr-4 text-slate-950">{row.name}</td>
                        <td class="py-2 pr-4 text-slate-600">{row.email}</td>
                        <td class="py-2 pr-4 text-slate-600">
                          {row.role ?? "user"}
                        </td>
                        <td class="py-2 text-slate-600">
                          {formatDate(row.createdAt)}
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            ) : (
              <p class="mt-4 text-slate-500">No users found.</p>
            )
          }
        </div>
      </section>
    </div>
  </main>
</BaseLayout>
