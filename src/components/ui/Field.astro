---
interface Props {
  id: string;
  label: string;
  hint?: string;
  error?: string;
  required?: boolean;
  class?: string;
}

const {
  id,
  label,
  hint,
  error,
  required = false,
  class: className,
} = Astro.props;
---

<div class={['space-y-2', className].filter(Boolean).join(' ')}>
  <label for={id} class="block text-sm font-medium text-slate-800">
    {label}
    {
      required && (
        <span class="ml-1 text-slate-400" aria-hidden="true">
          *
        </span>
      )
    }
  </label>

  <slot />

  {
    hint && !error && (
      <p id={`${id}-hint`} class="text-sm leading-6 text-slate-500">
        {hint}
      </p>
    )
  }

  {
    error && (
      <p id={`${id}-error`} class="text-sm leading-6 text-red-600">
        {error}
      </p>
    )
  }
</div>
