---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { appConfig } from "@/config/app";

interface Props {
  title: string;
  eyebrow: string;
  description: string;
}

const { title, eyebrow, description } = Astro.props;
---

<BaseLayout title={`${title} | ${appConfig.name}`}>
  <main
    class="min-h-screen bg-slate-50 px-4 py-8 text-slate-950 sm:px-6 lg:px-8"
  >
    <section
      class="mx-auto grid min-h-[calc(100vh-4rem)] w-full max-w-6xl items-center gap-8 lg:grid-cols-[0.95fr_1.05fr]"
    >
      <div class="hidden lg:block">
        <a
          href="/"
          class="inline-flex items-center gap-3 text-sm font-semibold text-slate-950"
        >
          <img src="/favicon.svg" alt={appConfig.name} class="h-6" />
          {appConfig.name}
        </a>

        <div class="mt-14 max-w-md">
          <p class="text-sm font-medium text-emerald-700">{eyebrow}</p>
          <h1
            class="mt-4 text-4xl font-semibold tracking-normal text-slate-950"
          >
            {title}
          </h1>
          <p class="mt-4 text-base leading-7 text-slate-600 mb-8">{description}</p>
        </div>
      </div>

      <div
        class="mx-auto w-full max-w-md rounded-xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8"
      >
        <div class="mb-8 lg:hidden">
          <a
            href="/"
            class="inline-flex items-center gap-3 text-sm font-semibold text-slate-950"
          >
            <img src="/favicon.svg" alt={appConfig.name} class="h-6" />
            {appConfig.name}
          </a>

          <p class="mt-8 text-sm font-medium text-emerald-700">{eyebrow}</p>
          <h1
            class="mt-3 text-3xl font-semibold tracking-normal text-slate-950"
          >
            {title}
          </h1>
          <p class="mt-3 text-sm leading-6 text-slate-600">{description}</p>
        </div>

        <slot />
      </div>
    </section>
  </main>

  <script>
    import { mountAuthForms } from '@vergekit/core/auth';
    import { appConfig } from '@/config/app';
    import { authConfig } from '@/config/auth';

    mountAuthForms(document, {
      authConfig,
      defaultSuccessRedirect: appConfig.defaultAuthenticatedPath,
    });
  </script>
</BaseLayout>
