# Copy to .dev.vars for local development.
# Do not commit .dev.vars.
#
# Source-level app defaults live in src/config. Committed non-secret runtime
# vars live in wrangler.jsonc. Add local overrides here only when your machine
# needs to differ from wrangler.jsonc.

# Better Auth requires a stable local secret. Use at least 32 random characters.
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
BETTER_AUTH_URL=http://localhost:4321

# Optional local sender overrides used by non-console email providers.
# EMAIL_FROM=VK <noreply@example.com>
# EMAIL_REPLY_TO=support@example.com

# Optional local provider secrets and overrides. Configure only the provider
# selected in wrangler.jsonc or by your local override.
# RESEND_API_KEY=
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=
